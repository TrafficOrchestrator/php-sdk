{
    "name": "traffic-orchestrator/sdk",
    "description": "Traffic Orchestrator License Validation SDK for PHP",
    "version": "2.0.0",
    "type": "library",
    "license": "MIT",
    "homepage": "https://trafficorchestrator.com/docs/sdks/php",
    "authors": [
        {
            "name": "Traffic Orchestrator",
            "email": "support@trafficorchestrator.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-sodium": "*"
    },
    "autoload": {
        "psr-4": {
            "TrafficOrchestrator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TrafficOrchestrator\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "squizlabs/php_codesniffer": "^3.8",
        "phpstan/phpstan": "^1.10"
    },
    "scripts": {
        "test": "phpunit tests",
        "lint": "phpcs src tests",
        "analyze": "phpstan analyse src tests --level=max"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "keywords": ["licensing", "license-validation", "traffic-orchestrator", "sdk", "api-client"],
    "support": {
        "issues": "https://github.com/Traffic-Orchestrator/TO/issues",
        "source": "https://github.com/Traffic-Orchestrator/TO"
    }
}